Windows Registry Editor Version 5.00

; Right-click on a FOLDER -> "Claude from here"
[HKEY_CURRENT_USER\Software\Classes\Directory\shell\ClaudeFromHere]
@="Claude from here"
"Icon"="C:\\Users\\jfago\\.local\\bin\\claude.exe"

[HKEY_CURRENT_USER\Software\Classes\Directory\shell\ClaudeFromHere\command]
@="cmd.exe /c start \"Claude\" wt.exe -d \"%V\" cmd /k claude"

; Right-click on folder BACKGROUND (inside a folder) -> "Claude from here"
[HKEY_CURRENT_USER\Software\Classes\Directory\Background\shell\ClaudeFromHere]
@="Claude from here"
"Icon"="C:\\Users\\jfago\\.local\\bin\\claude.exe"

[HKEY_CURRENT_USER\Software\Classes\Directory\Background\shell\ClaudeFromHere\command]
@="cmd.exe /c start \"Claude\" wt.exe -d \"%V\" cmd /k claude"
