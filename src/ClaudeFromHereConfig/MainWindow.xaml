<Window x:Class="ClaudeFromHereConfig.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude From Here &#x2014; Settings"
        MinWidth="500" MinHeight="480"
        Width="520" Height="560"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Icon="pack://siteoforigin:,,,/settings.ico"
        Background="{StaticResource DominantBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="4"
                      GlassFrameThickness="-1" CornerRadius="8"/>
    </WindowChrome.WindowChrome>
    <DockPanel>
        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Height="32" Background="{StaticResource DominantBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0">
                <Image Source="pack://siteoforigin:,,,/settings.ico" Width="16" Height="16" Margin="0,0,8,0"/>
                <TextBlock Text="Claude From Here &#x2014; Settings"
                           VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource ForegroundBrush}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinButton" Style="{StaticResource CaptionButton}"
                        Content="&#xE921;" Click="MinButton_Click" ToolTip="Minimize"/>
                <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}"
                        Content="&#xE922;" Click="MaxButton_Click" ToolTip="Maximize"/>
                <Button x:Name="CloseButton" Style="{StaticResource CloseCaptionButton}"
                        Content="&#xE8BB;" Click="CloseButton_Click" ToolTip="Close"/>
            </StackPanel>
        </Grid>
        <!-- Bottom button bar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="16,16,16,16">
            <Button Content="Discard Changes" Width="110"
                    Style="{StaticResource SecondaryButton}"
                    Click="DiscardChanges_Click" Margin="0,0,8,0"/>
            <Button Content="Apply Settings" Width="110"
                    Style="{StaticResource AccentButton}"
                    IsDefault="True"
                    Click="ApplySettings_Click"/>
        </StackPanel>

        <!-- Tab control fills remaining space -->
        <TabControl Margin="16,0,16,0">
            <!-- General tab -->
            <TabItem Header="General">
                <StackPanel Margin="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Model -->
                        <Label Grid.Row="0" Grid.Column="0" Content="Model:"
                               VerticalAlignment="Center"/>
                        <ComboBox x:Name="modelComboBox" Grid.Row="0" Grid.Column="1"
                                  IsEditable="False" Margin="0,0,0,8">
                            <ComboBoxItem Content="(default &#x2014; no flag)" IsSelected="True"/>
                            <ComboBoxItem Content="claude-opus-4-5"/>
                            <ComboBoxItem Content="claude-sonnet-4-5"/>
                            <ComboBoxItem Content="claude-haiku-3-5"/>
                            <ComboBoxItem Content="sonnet"/>
                            <ComboBoxItem Content="opus"/>
                            <ComboBoxItem Content="haiku"/>
                        </ComboBox>

                        <!-- Verbose -->
                        <CheckBox x:Name="verboseCheckBox" Grid.Row="1" Grid.Column="1"
                                  Content="Enable verbose mode (--verbose)" Margin="0,4,0,4"/>

                        <!-- Continue -->
                        <CheckBox x:Name="continueCheckBox" Grid.Row="2" Grid.Column="1"
                                  Content="-c  Continue the most recent conversation" Margin="0,4,0,4"/>

                        <!-- Resume -->
                        <CheckBox x:Name="resumeCheckBox" Grid.Row="3" Grid.Column="1"
                                  Content="-r  Resume a specific conversation" Margin="0,4,0,4"/>
                    </Grid>

                    <!-- Path Detection -->
                    <GroupBox Header="Path Detection" Margin="0,24,0,0" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="claude.exe:"/>
                            <TextBlock x:Name="claudePathText" Grid.Row="0" Grid.Column="1"
                                       FontFamily="Consolas" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,0,4"
                                       Text="Detecting..."/>

                            <Label Grid.Row="1" Grid.Column="0" Content="wt.exe:"/>
                            <TextBlock x:Name="wtPathText" Grid.Row="1" Grid.Column="1"
                                       FontFamily="Consolas" FontSize="12"
                                       VerticalAlignment="Center"
                                       Text="Detecting..."/>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- Advanced tab -->
            <TabItem Header="Advanced">
                <StackPanel Margin="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Allowed Tools -->
                        <Label Grid.Row="0" Grid.Column="0" Content="Allowed Tools:"
                               VerticalAlignment="Center"/>
                        <TextBox x:Name="allowedToolsTextBox" Grid.Row="0" Grid.Column="1"
                                 Margin="0,0,0,8"/>

                        <!-- Extra Flags -->
                        <Label Grid.Row="1" Grid.Column="0" Content="Extra Flags:"
                               VerticalAlignment="Center"/>
                        <TextBox x:Name="extraFlagsTextBox" Grid.Row="1" Grid.Column="1"
                                 Margin="0,0,0,8"/>
                    </Grid>

                    <!-- Dangerous Permissions -->
                    <GroupBox Header="Dangerous Permissions" Margin="0,16,0,0" Padding="8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{StaticResource DestructiveBrush}"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <CheckBox x:Name="dangerSkipCheckBox" VerticalAlignment="Center"/>
                                <TextBlock Text="--dangerously-skip-permissions  Skip all permission checks"
                                           Foreground="{StaticResource DestructiveBrush}"
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{StaticResource DestructiveBrush}"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <CheckBox x:Name="allowDangerSkipCheckBox" VerticalAlignment="Center"/>
                                <TextBlock Text="--allow-dangerously-skip-permissions  Allow MCP servers to skip permissions"
                                           Foreground="{StaticResource DestructiveBrush}"
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="These flags bypass Claude Code safety checks. Use only in controlled environments."
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Remote control prefix -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Session prefix:"
                               VerticalAlignment="Center"/>
                        <TextBox x:Name="remotePrefixTextBox" Grid.Column="1"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- Channels tab -->
            <TabItem Header="Channels">
                <DockPanel Margin="16">
                    <!-- Add channel row -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox x:Name="channelComboBox" IsEditable="True" Width="350">
                            <ComboBoxItem Content="Telegram"/>
                            <ComboBoxItem Content="Discord"/>
                        </ComboBox>
                        <Button Content="Add" Style="{StaticResource AccentButton}"
                                Click="AddChannel_Click" Margin="8,0,0,0" Width="60"/>
                    </StackPanel>

                    <!-- Channel list -->
                    <ListBox x:Name="ChannelListBox" MinHeight="96">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right" Content="Remove"
                                            DataContext="{Binding}"
                                            Click="RemoveChannel_Click"
                                            Width="60" Margin="4,0,0,0"/>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
